{
  "name": "screenshare-app",
  "version": "1.0.11",
  "description": "Application de partage d'écran basée sur Electron et WebRTC",
  "main": "main.js",
  "author": {
    "name": "Enzo D.",
    "email": "davalenzo@gmail.com",
    "url": "https://github.com/davalenzo"
  },
  "scripts": {
    "start": "electron .",
    "start:unsafe": "electron . --enable-features=ElectronSerialChooser --disable-web-security",
    "start:safe": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "build:all": "electron-builder --win nsis portable",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "electron-updater": "^6.1.8",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.screenshare.app",
    "productName": "ScreenShare Pro",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DavalEnzo",
        "repo": "share-screen",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
